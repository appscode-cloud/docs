{
  "scripts": {
    "dev": "vitepress dev",
    "build": "run-p type-check build-only",
    "build-only": "vitepress build",
    "preview": "vitepress preview",
    "type-check": "vue-tsc --noEmit",
    "lint:es": "eslint .",
    "lint:style": "stylelint .vitepress/theme/**.{css,scss,sass}",
    "lint-fix:es": "eslint . --fix",
    "lint-fix:style": "stylelint .vitepress/theme/**.{css,scss,sass} --fix",
    "format": "run-p lint-fix:*"
  },
  "dependencies": {
    "@appscode/design-system": "^1.1.0-beta.20",
    "@vueuse/core": "^10.1.2",
    "@vueuse/integrations": "^10.1.2",
    "bulma": "^0.9.4",
    "font-awesome": "^4.7.0",
    "pinia": "^2.1.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^0.39.5",
    "@rushstack/eslint-patch": "^1.3.1",
    "@tsconfig/node18": "^2.0.1",
    "@types/node": "^20.2.5",
    "@vue/tsconfig": "^0.4.0",
    "eslint": "^8.42.0",
    "npm-run-all": "^4.1.5",
    "postcss-html": "^1.5.0",
    "sass": "^1.62.1",
    "sass-loader": "^13.3.1",
    "stylelint": "^15.7.0",
    "stylelint-config-recommended-scss": "^12.0.0",
    "stylelint-config-recommended-vue": "^1.4.0",
    "stylelint-config-standard": "^33.0.0",
    "stylelint-config-standard-scss": "^9.0.0",
    "typescript": "^5.0.4",
    "universal-cookie": "^4.0.4",
